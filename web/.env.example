# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored.

# Neon Postgres connection string.
# Get it from https://neon.tech → your project → "Connection Details"
# Use the "pooled" connection string for the Neon serverless driver.
DATABASE_URL="postgresql://<user>:<password>@<host>/<dbname>?sslmode=require"

# Clerk auth — get from https://dashboard.clerk.com → your app → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk URL config (don't change unless you customise the auth routes)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL="/post-auth"
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL="/post-auth"

# Razorpay test mode — get from https://dashboard.razorpay.com → Settings → API Keys
# Make sure the "Test Mode" toggle is ON before generating.
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
