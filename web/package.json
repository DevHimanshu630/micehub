{
  "name": "micehub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "promote-admin": "node --env-file=.env.local scripts/promote-to-admin.mjs",
    "migrate:step8": "node --env-file=.env.local scripts/step8-migrate.mjs",
    "migrate:step9": "node --env-file=.env.local scripts/step9-migrate.mjs",
    "migrate:step11": "node --env-file=.env.local scripts/step11-migrate.mjs"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.1",
    "@neondatabase/serverless": "^1.1.0",
    "@react-pdf/renderer": "^4.5.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "razorpay": "^2.9.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
